&GLOBAL
  PROJECT_NAME H2_LINRTBSE_ABBA_CUTOFF
  RUN_TYPE RT_PROPAGATION
&END GLOBAL

! ABBA Liouvillian diagnostic with energy-cutoff truncation. Pinned via
! peak1+peak2+peak3 matchers to gate the cutoff bookkeeping on the
! Furche-reduction code path.

&MOTION
  &MD
    ENSEMBLE NVE
    STEPS 5
    TEMPERATURE [K] 0.0
    TIMESTEP [fs] 1e-3
  &END MD
&END MOTION

&FORCE_EVAL
  METHOD QS
  &DFT
    BASIS_SET_FILE_NAME BASIS_MINIMAL
    POTENTIAL_FILE_NAME ALL_POTENTIALS
    &MGRID
      CUTOFF 300
      REL_CUTOFF 40
    &END MGRID
    &QS
      EPS_DEFAULT 1.0E-10
      METHOD GAPW
    &END QS
    &POISSON
      PERIODIC NONE
      POISSON_SOLVER WAVELET
    &END POISSON
    &SCF
      SCF_GUESS ATOMIC
      EPS_SCF 1.0E-8
      MAX_SCF 200
      ADDED_MOS -1
      &DIAGONALIZATION ON
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.4
        NBROYDEN 4
      &END MIXING
    &END SCF
    &XC
      &XC_FUNCTIONAL PBE0
      &END XC_FUNCTIONAL
    &END XC
    &REAL_TIME_PROPAGATION
      INITIAL_WFN SCF_WFN
      APPLY_DELTA_PULSE
      DELTA_PULSE_DIRECTION 1 0 0
      DELTA_PULSE_SCALE 1.0E-5
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
      &RTBSE
        LRRTBSE T
        TDA F
        DIAGNOSE_LIOUVILLIAN_EIG T
        ENERGY_CUTOFF_OCC 20
        ENERGY_CUTOFF_EMPTY 40
      &END RTBSE
    &END REAL_TIME_PROPAGATION
  &END DFT
  &PROPERTIES
    &BANDSTRUCTURE
      &GW
        NUM_TIME_FREQ_POINTS 20
        &PRINT
          &RESTART OFF
          &END RESTART
        &END PRINT
      &END GW
    &END BANDSTRUCTURE
  &END PROPERTIES
  &SUBSYS
    &CELL
      ABC 10.0 10.0 10.0
      PERIODIC NONE
    &END CELL
    &TOPOLOGY
      &CENTER_COORDINATES
      &END CENTER_COORDINATES
    &END TOPOLOGY
    &COORD
      H 0.0 0.0 0.0
      H 0.74 0.0 0.0
    &END COORD
    &KIND H
      BASIS_SET ORB def2-SVP-custom
      BASIS_SET RI_AUX def2-SVP-RIFIT-custom
      POTENTIAL ALL
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
